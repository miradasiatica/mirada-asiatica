{{- $cutoff := now.AddDate 0 0 -2 -}}
{{- $pages := where .Site.RegularPages "Type" "in" .Site.Params.mainSections -}}
{{- printf `<?xml version="1.0" encoding="UTF-8"?>` | safeHTML }}
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9" xmlns:news="http://www.google.com/schemas/sitemap-news/0.9">
{{- range $pages }}
{{- if ge .Date.Unix $cutoff.Unix }}
  <url>
    <loc>{{ .Permalink }}</loc>
    <news:news>
      <news:publication>
        <news:name>{{ $.Site.Params.logo.title | default $.Site.Title }}</news:name>
        <news:language>es</news:language>
      </news:publication>
      <news:publication_date>{{ .Date.Format "2006-01-02T15:04:05-07:00" | safeHTML }}</news:publication_date>
      <news:title>{{ .Title }}</news:title>
    </news:news>
  </url>
{{- end }}
{{- end }}
</urlset>
